{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.test/sciemd/materials-study.schema.json",
  "title": "ScieMD Materials Study",
  "description": "Schema companion for materials-study-comprehensive.json. It is designed to exercise nested defaults, enums, arrays, descriptions, and required-field suggestions.",
  "type": "object",
  "required": ["study", "samples", "analysis"],
  "properties": {
    "study": {
      "type": "object",
      "required": ["id", "title", "status", "created_at", "version"],
      "additionalProperties": true,
      "properties": {
        "id": {
          "type": "string",
          "default": "SCMD-STRUCT-2026-NEW",
          "description": "Stable study identifier."
        },
        "title": {
          "type": "string",
          "default": "New structured materials study"
        },
        "status": {
          "type": "string",
          "enum": ["draft", "analysis-ready", "submitted", "archived"],
          "default": "draft"
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "updated_at": {
          "type": ["string", "null"],
          "format": "date-time",
          "default": null
        },
        "version": {
          "type": "integer",
          "minimum": 1,
          "default": 1
        },
        "is_blinded": {
          "type": "boolean",
          "default": false
        },
        "summary": {
          "type": "string",
          "default": "Short summary for the study."
        }
      }
    },
    "contacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["role", "name", "email", "active"],
        "properties": {
          "role": {
            "type": "string",
            "enum": ["principal_investigator", "data_steward", "analyst", "reviewer"],
            "default": "analyst"
          },
          "name": {
            "type": "string",
            "default": "New contact"
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "orcid": {
            "type": ["string", "null"],
            "default": null
          },
          "active": {
            "type": "boolean",
            "default": true
          }
        }
      }
    },
    "samples": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["sample_id", "batch", "substrate", "parameters", "measurements", "qc"],
        "properties": {
          "sample_id": {
            "type": "string",
            "default": "S-NEW"
          },
          "batch": {
            "type": "string",
            "default": "B-NEW"
          },
          "substrate": {
            "type": "string",
            "enum": ["glass", "silicon", "polyimide", "steel"],
            "default": "glass"
          },
          "operator": {
            "type": "string",
            "default": "AR"
          },
          "parameters": {
            "type": "object",
            "required": ["flow_rate_ml_min", "stage_speed_mm_s", "passes"],
            "properties": {
              "flow_rate_ml_min": {
                "type": "number",
                "minimum": 0,
                "default": 0.2
              },
              "stage_speed_mm_s": {
                "type": "number",
                "minimum": 0,
                "default": 8.0
              },
              "passes": {
                "type": "integer",
                "minimum": 1,
                "default": 3
              },
              "anneal_profile": {
                "type": "array",
                "minItems": 1,
                "maxItems": 5,
                "items": {
                  "type": "number",
                  "default": 85
                }
              }
            }
          },
          "measurements": {
            "type": "object",
            "required": ["thickness_nm", "roughness_nm", "defect_density_per_mm2", "coverage_percent"],
            "properties": {
              "thickness_nm": { "type": "number", "default": 120 },
              "roughness_nm": { "type": "number", "default": 8 },
              "defect_density_per_mm2": { "type": "number", "default": 0.5 },
              "coverage_percent": { "type": "number", "minimum": 0, "maximum": 100, "default": 98 }
            }
          },
          "qc": {
            "type": "object",
            "required": ["status", "reviewed", "flags"],
            "properties": {
              "status": {
                "type": "string",
                "enum": ["pass", "review", "fail"],
                "default": "review"
              },
              "reviewed": {
                "type": "boolean",
                "default": false
              },
              "flags": {
                "type": "array",
                "default": [],
                "items": {
                  "type": "string"
                }
              },
              "reviewed_at": {
                "type": ["string", "null"],
                "format": "date-time",
                "default": null
              }
            }
          }
        }
      }
    },
    "analysis": {
      "type": "object",
      "required": ["primary_metric", "model"],
      "properties": {
        "primary_metric": {
          "type": "string",
          "default": "coverage_percent"
        },
        "secondary_metrics": {
          "type": "array",
          "items": { "type": "string" },
          "default": ["thickness_nm", "roughness_nm"]
        },
        "model": {
          "type": "object",
          "required": ["name", "version", "performance"],
          "properties": {
            "name": { "type": "string", "default": "linear_regression" },
            "version": { "type": "string", "default": "0.1.0" },
            "random_seed": { "type": "integer", "default": 12345 },
            "performance": {
              "type": "object",
              "required": ["rmse", "r2"],
              "properties": {
                "rmse": { "type": "number", "default": 0 },
                "r2": { "type": "number", "default": 0 }
              }
            }
          }
        }
      }
    }
  }
}
