{
  "name": "sciemd",
  "version": "1.1.0",
  "description": "ScieMD scientific Markdown desktop editor",
  "type": "module",
  "workspaces": [
    "packages/core"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "test": "vitest run",
    "test:all": "vitest run && node scripts/milkdown-roundtrip.mjs --offline",
    "test:roundtrip:review": "node scripts/milkdown-roundtrip.mjs --review --offline",
    "test:watch": "vitest",
    "validate:release": "node scripts/validate-release.mjs",
    "validate:export": "node scripts/validate-welcome-export.mjs",
    "validate:styles": "node scripts/validate-style-modes.mjs",
    "validate:ux": "node scripts/validate-ux-workflows.mjs",
    "validate:distribution": "node scripts/validate-distribution-config.mjs",
    "validate:desktop-smoke": "node scripts/validate-desktop-smoke.mjs",
    "validate:vscode-package": "node scripts/validate-vscode-package.mjs",
    "validate:vscode-host-smoke": "npm --prefix scie-md-vscode-extension run test:host-smoke",
    "validate:vscode-visual-smoke": "npm --prefix scie-md-vscode-extension run test:visual-smoke",
    "validate:vscode-installed-smoke": "node scripts/validate-vscode-installed-smoke.mjs",
    "validate:package-budgets": "node scripts/validate-package-budgets.mjs",
    "validate:tauri-contract": "node scripts/validate-tauri-command-contract.mjs",
    "validate:version-changelog": "node scripts/validate-version-changelog.mjs",
    "validate:generated-outputs": "node scripts/validate-generated-outputs.mjs",
    "validate:generated-outputs:self-test": "node scripts/validate-generated-outputs.mjs --self-test",
    "validate:merge": "node scripts/validate-merge.mjs",
    "validate:structured-workflows": "node scripts/validate-structured-workflows.mjs",
    "validate:large-document-stress": "node scripts/validate-large-document-stress.mjs",
    "build:desktop": "tauri build",
    "build:desktop:linux": "tauri build --bundles deb,appimage",
    "copy:exe": "node scripts/copy-release-exe.mjs",
    "install:vscode": "npm --prefix scie-md-vscode-extension ci",
    "package:vscode": "npm --prefix scie-md-vscode-extension run package",
    "stage:vscode": "node scripts/stage-vscode-extension.mjs",
    "release:local": "npm run install:vscode && npm run validate:release && npm run build:desktop && npm run validate:desktop-smoke -- --required && npm run copy:exe && npm run package:vscode && npm run validate:vscode-package && npm run validate:vscode-installed-smoke -- --required && npm run stage:vscode && npm run validate:generated-outputs",
    "fonts:scie-sans": "node scripts/run-python.mjs scripts/fonts/build-scie-sans.py",
    "fonts:verify": "node scripts/run-python.mjs scripts/fonts/verify-scie-sans.py",
    "spike:milkdown": "node scripts/milkdown-roundtrip.mjs",
    "spike:milkdown:review": "node scripts/milkdown-roundtrip.mjs --review",
    "spike:toml-preservation": "cargo test --manifest-path src-tauri/Cargo.toml --test toml_preservation_spike"
  },
  "keywords": [
    "markdown",
    "tauri",
    "scientific-writing",
    "local-first"
  ],
  "author": "Scienfy Inc.",
  "license": "AGPL-3.0-or-later",
  "homepage": "https://scienfy.com",
  "bugs": {
    "url": "https://github.com/scienfy/scie-md/issues"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.3",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-xml": "^6.1.0",
    "@codemirror/lang-yaml": "^6.1.3",
    "@codemirror/language": "^6.12.3",
    "@codemirror/lint": "^6.9.7",
    "@codemirror/search": "^6.7.1",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.1",
    "@fontsource/ibm-plex-sans": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/lora": "^5.2.8",
    "@fontsource/source-serif-4": "^5.2.9",
    "@milkdown/kit": "^7.21.2",
    "@milkdown/react": "^7.21.2",
    "@milkdown/theme-nord": "^7.21.2",
    "@milkdown/utils": "^7.21.2",
    "@sciemd/core": "file:packages/core",
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "dompurify": "^3.4.7",
    "katex": "^0.17.0",
    "lucide-react": "^1.21.0",
    "markdown-it": "^14.1.1",
    "markdown-it-deflist": "^3.0.1",
    "markdown-it-footnote": "^4.0.0",
    "markdown-it-task-lists": "^2.1.1",
    "mermaid": "^11.15.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.2",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "axe-core": "^4.12.1",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.13",
    "vitest": "^4.1.9"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/scienfy/scie-md.git"
  }
}
